    "cosmosCollections": {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}/{2}', format('cosmos-{0}', variables('resourceToken')), parameters('cosmosDbName'), 'collections')]",
      "properties": {
        "resource": {
          "id": "collections",
          "partitionKey": {
            "paths": [
              "/collection"
            ],
            "kind": "Hash",
            "version": 2
          },
          "indexingPolicy": {
            "indexingMode": "consistent",
            "automatic": true,
            "includedPaths": [
              {
                "path": "/*"
              }
            ],
            "excludedPaths": [
              {
                "path": "/data/*"
              },
              {
                "path": "/_etag/?"
              }
            ]
          },
          "defaultTtl": -1
        }
      },
      "dependsOn": [
        "cosmosDb"
      ]
    },
    "cosmosUsage": {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}/{2}', format('cosmos-{0}', variables('resourceToken')), parameters('cosmosDbName'), 'usage')]",
      "properties": {
        "resource": {
          "id": "usage",
          "partitionKey": {
            "paths": [
              "/sessionId"
            ],
            "kind": "Hash",
            "version": 2
          }
        }
      },
      "dependsOn": [
        "cosmosDb"
      ]
    },
    "cosmosDataRole": {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlRoleAssignments",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}', format('cosmos-{0}', variables('resourceToken')), guid('data-contributor', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('msi-{0}', parameters('environmentName'))), resourceId('Microsoft.DocumentDB/databaseAccounts', format('cosmos-{0}', variables('resourceToken')))))]",
      "properties": {
        "principalId": "[reference('identity').principalId]",
        "roleDefinitionId": "[format('{0}/sqlRoleDefinitions/00000000-0000-0000-0000-000000000002', resourceId('Microsoft.DocumentDB/databaseAccounts', format('cosmos-{0}', variables('resourceToken'))))]",
        "scope": "[resourceId('Microsoft.DocumentDB/databaseAccounts', format('cosmos-{0}', variables('resourceToken')))]"
      },
      "dependsOn": [
        "cosmosAccount",
        "identity"
      ]
    },
    "cosmosPrivateEndpoint": {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-11-01",
      "name": "[format('pe-cosmos-{0}', variables('resourceToken'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "subnet": {
          "id": "[reference('vnet').subnets[1].id]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "cosmos",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.DocumentDB/databaseAccounts', format('cosmos-{0}', variables('resourceToken')))]",
              "groupIds": [
                "Sql"
              ]
            }
          }
        ]
      },
      "dependsOn": [
