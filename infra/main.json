    "cosmosDnsGroup": {
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', format('pe-cosmos-{0}', variables('resourceToken')), 'cosmos-dns')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "cosmos",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.documents.azure.com')]"
            }
          }
        ]
      },
      "dependsOn": [
        "cosmosDnsZone",
        "cosmosPrivateEndpoint"
      ]
    },
    "containerAppEnv": {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[format('cae-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference('logAnalytics').customerId]",
            "sharedKey": "[listKeys('logAnalytics', '2023-09-01').primarySharedKey]"
          }
        },
        "vnetConfiguration": {
          "infrastructureSubnetId": "[reference('vnet').subnets[0].id]",
          "internal": false
        },
        "workloadProfiles": [
          {
            "name": "Consumption",
            "workloadProfileType": "Consumption"
          }
        ]
      },
      "dependsOn": [
        "logAnalytics",
        "vnet"
      ]
    },
    "envStorage": {
      "type": "Microsoft.App/managedEnvironments/storages",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}/{1}', format('cae-{0}', parameters('environmentName')), 'tailscale-state')]",
      "properties": {
        "azureFile": {
          "accountName": "[format('st{0}', variables('resourceToken'))]",
          "accountKey": "[listKeys('storageAccount', '2023-05-01').keys[0].value]",
          "shareName": "tailscale-state",
          "accessMode": "ReadWrite"
        }
      },
      "dependsOn": [
        "containerAppEnv",
        "fileShare",
        "storageAccount"
      ]
    },
    "envAppDataStorage": {
      "type": "Microsoft.App/managedEnvironments/storages",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}/{1}', format('cae-{0}', parameters('environmentName')), 'swarmclaw-data')]",
      "properties": {
        "azureFile": {
          "accountName": "[format('st{0}', variables('resourceToken'))]",
          "accountKey": "[listKeys('storageAccount', '2023-05-01').keys[0].value]",
          "shareName": "swarmclaw-data",
          "accessMode": "ReadWrite"
        }
      },
      "dependsOn": [
        "appDataShare",
        "containerAppEnv",
        "storageAccount"
      ]
    },
    "containerApp": {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "swarmclaw",
      "location": "[parameters('location')]",
      "tags": "[union(variables('tags'), createObject('azd-service-name', 'swarmclaw'))]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('msi-{0}', parameters('environmentName'))))]": {}
        }
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}', parameters('environmentName')))]",
        "workloadProfileName": "Consumption",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 3456,
            "transport": "auto",
            "allowInsecure": false
          },
          "registries": [
            {
              "server": "[reference('acr').loginServer]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('msi-{0}', parameters('environmentName')))]"
            }
          ],
          "secrets": [
            {
              "name": "ts-auth-key",
              "keyVaultUrl": "[format('{0}secrets/tailscale-auth-key', reference('keyVault').vaultUri)]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('msi-{0}', parameters('environmentName')))]"
            },
            {
              "name": "override-use-mi-fic-assertion-client-id",
              "value": "[reference('identity').clientId]"
            }
          ]
        },
        "template": {
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 3,
            "rules": [
              {
                "name": "http-scaling",
                "http": {
                  "metadata": {
                    "concurrentRequests": "50"
                  }
                }
              }
            ]
          },
          "containers": [
            {
              "name": "swarmclaw",
              "image": "[parameters('appImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "NODE_ENV",
                  "value": "production"
                },
                {
                  "name": "PORT",
                  "value": "3456"
                },
                {
                  "name": "HOSTNAME",
                  "value": "0.0.0.0"
                },
                {
                  "name": "AZURE_CLIENT_ID",
                  "value": "[reference('identity').clientId]"
                }
              ]
            },
            {
              "name": "tailscale",
              "image": "ghcr.io/tailscale/tailscale:latest",
              "command": [
                "/bin/sh"
              ],
              "args": [
                "-c",
                "export KUBERNETES_SERVICE_HOST=\"\" && /usr/local/bin/containerboot"
              ],
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              },
              "env": [
                {
                  "name": "TS_AUTHKEY",
                  "secretRef": "ts-auth-key"
                },
                {
                  "name": "TS_HOSTNAME",
                  "value": "[parameters('tailscaleHostname')]"
                },
                {
                  "name": "TS_STATE_DIR",
                  "value": "/var/lib/tailscale"
                },
                {
                  "name": "TS_USERSPACE",
                  "value": "true"
                },
                {
                  "name": "TS_AUTH_ONCE",
                  "value": "true"
                },
                {
                  "name": "TS_EXTRA_ARGS",
                  "value": "--advertise-exit-node"
                }
              ],
              "volumeMounts": [
                {
                  "volumeName": "ts-state",
                  "mountPath": "/var/lib/tailscale"
                }
              ]
            }
          ],
          "volumes": [
            {
              "name": "ts-state",
              "storageName": "tailscale-state",
              "storageType": "AzureFile"
            }
          ]
        }
      },
      "dependsOn": [
        "acr",
        "containerAppEnv",
        "envStorage",
        "identity",
        "keyVault"
      ]
    },
    "authConfig": {
      "type": "Microsoft.App/containerApps/authConfigs",
      "apiVersion": "2024-10-02-preview",
      "name": "[format('{0}/{1}', 'swarmclaw', 'current')]",
      "properties": {
        "platform": {
          "enabled": true
        },
        "globalValidation": {
          "unauthenticatedClientAction": "RedirectToLoginPage",
          "redirectToProvider": "azureactivedirectory",
          "excludedPaths": [
            "/api/daemon/health-check"
          ]
        },
        "identityProviders": {
          "azureActiveDirectory": {
            "enabled": true,
            "registration": {
              "clientId": "[reference('entraApp').appId]",
              "clientSecretSettingName": "override-use-mi-fic-assertion-client-id",
              "openIdIssuer": "[variables('openIdIssuer')]"
            },
            "validation": {
              "allowedAudiences": [
                "[format('api://{0}', reference('entraApp').appId)]",
                "[reference('entraApp').appId]"
              ]
            }
          }
        },
        "httpSettings": {
          "requireHttps": true,
          "forwardProxy": "[if(parameters('enableWaf'), createObject('convention', 'Custom', 'customHostHeaderName', 'X-Forwarded-Host', 'customProtoHeaderName', 'X-Forwarded-Proto'), null())]"
        }
      },
      "dependsOn": [
        "containerApp",
        "entraApp"
      ]
    },
    "wafPolicy": {
      "condition": "[parameters('enableWaf')]",
      "type": "Microsoft.Network/FrontDoorWebApplicationFirewallPolicies",
      "apiVersion": "2024-02-01",
      "name": "[format('waf{0}', replace(parameters('environmentName'), '-', ''))]",
      "location": "global",
      "tags": "[variables('tags')]",
      "sku": {
        "name": "Standard_AzureFrontDoor"
      },
      "properties": {
        "policySettings": {
          "enabledState": "Enabled",
          "mode": "Prevention",
          "requestBodyCheck": "Enabled"
        },
        "customRules": {
          "rules": [
            {
              "name": "RateLimitGlobal",
              "priority": 100,
              "ruleType": "RateLimitRule",
              "action": "Block",
              "rateLimitDurationInMinutes": 1,
              "rateLimitThreshold": 200,
              "matchConditions": [
                {
                  "matchVariable": "RemoteAddr",
                  "operator": "IPMatch",
                  "negateCondition": true,
                  "matchValue": [
                    "192.0.2.0/24"
                  ]
                }
              ]
            },
            {
              "name": "BlockBadBots",
              "priority": 200,
              "ruleType": "MatchRule",
              "action": "Block",
              "matchConditions": [
                {
                  "matchVariable": "RequestHeader",
                  "selector": "User-Agent",
                  "operator": "Contains",
                  "matchValue": [
                    "sqlmap",
                    "nikto",
                    "nmap",
                    "masscan",
                    "zgrab"
                  ],
                  "transforms": [
                    "Lowercase"
                  ]
                }
              ]
            }
          ]
        }
      }
    },
    "frontDoor": {
      "condition": "[parameters('enableWaf')]",
      "type": "Microsoft.Cdn/profiles",
      "apiVersion": "2024-09-01",
      "name": "[format('fd-{0}', parameters('environmentName'))]",
      "location": "global",
      "tags": "[variables('tags')]",
      "sku": {
        "name": "Standard_AzureFrontDoor"
      }
    },
    "fdEndpoint": {
      "condition": "[parameters('enableWaf')]",
      "type": "Microsoft.Cdn/profiles/afdEndpoints",
      "apiVersion": "2024-09-01",
      "name": "[format('{0}/{1}', format('fd-{0}', parameters('environmentName')), 'swarmclaw')]",
      "location": "global",
      "properties": {
        "enabledState": "Enabled"
      },
      "dependsOn": [
        "frontDoor"
      ]
    },
    "fdOriginGroup": {
      "condition": "[parameters('enableWaf')]",
      "type": "Microsoft.Cdn/profiles/originGroups",
      "apiVersion": "2024-09-01",
      "name": "[format('{0}/{1}', format('fd-{0}', parameters('environmentName')), 'swarmclaw-origins')]",
      "properties": {
        "loadBalancingSettings": {
          "sampleSize": 4,
          "successfulSamplesRequired": 3,
          "additionalLatencyInMilliseconds": 50
        },
        "healthProbeSettings": {
          "probePath": "/api/daemon/health-check",
          "probeRequestType": "HEAD",
          "probeProtocol": "Https",
          "probeIntervalInSeconds": 100
        }
      },
      "dependsOn": [
        "frontDoor"
      ]
    },
    "fdOrigin": {
      "condition": "[parameters('enableWaf')]",
      "type": "Microsoft.Cdn/profiles/originGroups/origins",
      "apiVersion": "2024-09-01",
      "name": "[format('{0}/{1}/{2}', format('fd-{0}', parameters('environmentName')), 'swarmclaw-origins', 'swarmclaw-aca')]",
      "properties": {
        "hostName": "[reference('containerApp').configuration.ingress.fqdn]",
        "originHostHeader": "[reference('containerApp').configuration.ingress.fqdn]",
        "httpPort": 80,
        "httpsPort": 443,
        "priority": 1,
        "weight": 1000,
        "enabledState": "Enabled",
        "enforceCertificateNameCheck": true
      },
      "dependsOn": [
        "containerApp",
        "fdOriginGroup"
      ]
    },
    "fdRoute": {
      "condition": "[parameters('enableWaf')]",
      "type": "Microsoft.Cdn/profiles/afdEndpoints/routes",
      "apiVersion": "2024-09-01",
      "name": "[format('{0}/{1}/{2}', format('fd-{0}', parameters('environmentName')), 'swarmclaw', 'default-route')]",
      "properties": {
        "originGroup": {
          "id": "[resourceId('Microsoft.Cdn/profiles/originGroups', format('fd-{0}', parameters('environmentName')), 'swarmclaw-origins')]"
        },
        "patternsToMatch": [
          "/*"
        ],
        "forwardingProtocol": "HttpsOnly",
        "httpsRedirect": "Enabled",
        "linkToDefaultDomain": "Enabled",
        "supportedProtocols": [
          "Http",
          "Https"
        ]
      },
      "dependsOn": [
        "fdEndpoint",
        "fdOrigin",
        "fdOriginGroup"
      ]
    },
    "fdSecurityPolicy": {
      "condition": "[parameters('enableWaf')]",
      "type": "Microsoft.Cdn/profiles/securityPolicies",
      "apiVersion": "2024-09-01",
      "name": "[format('{0}/{1}', format('fd-{0}', parameters('environmentName')), 'waf-policy')]",
      "properties": {
        "parameters": {
          "type": "WebApplicationFirewall",
          "wafPolicy": {
            "id": "[resourceId('Microsoft.Network/FrontDoorWebApplicationFirewallPolicies', format('waf{0}', replace(parameters('environmentName'), '-', '')))]"
          },
          "associations": [
            {
              "domains": [
                {
                  "id": "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', format('fd-{0}', parameters('environmentName')), 'swarmclaw')]"
                }
              ],
              "patternsToMatch": [
                "/*"
              ]
            }
          ]
        }
      },
      "dependsOn": [
        "fdEndpoint",
        "frontDoor",
        "wafPolicy"
      ]
    },
    "cosmosDiag": {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.DocumentDB/databaseAccounts', format('cosmos-{0}', variables('resourceToken')))]",
      "name": "cosmos-diag",
      "properties": {
        "workspaceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('environmentName')))]",
        "logs": [
          {
            "categoryGroup": "allLogs",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "Requests",
            "enabled": true
          }
        ]
      },
      "dependsOn": [
        "cosmosAccount",
        "logAnalytics"
      ]
    },
    "kvDiag": {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', format('kv-{0}', variables('resourceToken')))]",
      "name": "kv-diag",
      "properties": {
        "workspaceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('environmentName')))]",
        "logs": [
          {
            "categoryGroup": "allLogs",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true
          }
        ]
      },
      "dependsOn": [
        "keyVault",
        "logAnalytics"
      ]
    }
  },
  "outputs": {
    "containerAppFqdn": {
      "type": "string",
      "value": "[reference('containerApp').configuration.ingress.fqdn]"
    },
    "containerAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference('containerApp').configuration.ingress.fqdn)]"
    },
    "frontDoorUrl": {
      "type": "string",
      "value": "[if(parameters('enableWaf'), format('https://{0}', reference('fdEndpoint').hostName), 'N/A')]"
    },
    "frontDoorId": {
      "type": "string",
      "value": "[if(parameters('enableWaf'), reference('frontDoor').frontDoorId, 'N/A')]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference('cosmosAccount').documentEndpoint]"
    },
    "AZURE_CONTAINER_REGISTRY_ENDPOINT": {
      "type": "string",
      "value": "[reference('acr').loginServer]"
    },
    "managedIdentityClientId": {
      "type": "string",
      "value": "[reference('identity').clientId]"
    },
    "tailscaleHostname": {
      "type": "string",
      "value": "[parameters('tailscaleHostname')]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[format('kv-{0}', variables('resourceToken'))]"
    },
    "entraAppId": {
      "type": "string",
      "value": "[reference('entraApp').appId]"
    },
    "vnetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', format('vnet-{0}', parameters('environmentName')))]"
    }
  }
}