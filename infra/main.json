      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', format('kv-{0}', variables('resourceToken'))), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('msi-{0}', parameters('environmentName'))), '4633458b-17de-408a-b874-0445c86b69e6')]",
      "properties": {
